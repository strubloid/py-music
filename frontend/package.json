{
  "name": "music-theory-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=22 <25"
  },
  "scripts": {
    "audit": "npm audit --audit-level=high",
    "dev": "vite --host",
    "dev:open": "vite --host --open",
    "build": "vite build",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "serve": "vite preview --host",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "format": "prettier --write . ../package.json ../CONTRIBUTING.md ../.github/workflows/*.yml",
    "format:check": "prettier --check . ../package.json ../CONTRIBUTING.md ../.github/workflows/*.yml",
    "test:e2e": "playwright test",
    "test:coverage": "tsx --test src/features/ear-game/tests/*.test.ts && vitest run --coverage --coverage.reporter=text --coverage.reporter=html --coverage.reporter=lcov",
    "test:unit": "npm run test:unit:node && npm run test:unit:vitest",
    "test:unit:node": "tsx --test src/features/ear-game/tests/*.test.ts",
    "test:unit:vitest": "vitest run",
    "test:visual": "playwright test e2e/living-city.visual.spec.ts"
  },
  "dependencies": {
    "@radix-ui/react-select": "^2.0.0",
    "@radix-ui/react-tabs": "^1.0.4",
    "@rive-app/react-canvas": "^4.29.5",
    "@vitejs/plugin-react": "^4.2.1",
    "@xstate/react": "^6.1.0",
    "autoprefixer": "^10.4.22",
    "axios": "^1.6.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.0.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.294.0",
    "phaser": "^3.90.0",
    "pixi.js": "^8.19.0",
    "postcss": "^8.5.6",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.30.4",
    "smplr": "^1.0.0",
    "tailwind-merge": "^2.0.0",
    "tailwindcss": "^3.4.19",
    "tone": "^15.1.22",
    "vite": "^6.4.3",
    "xstate": "^5.32.5"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.2",
    "@playwright/test": "^1.54.1",
    "@storybook/addon-a11y": "^8.6.14",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/react-vite": "^8.6.14",
    "@storybook/test": "^8.6.14",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.0.0",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.64.0",
    "@vitest/coverage-v8": "^3.2.7",
    "eslint": "^8.55.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "jsdom": "^26.1.0",
    "prettier": "^3.6.2",
    "sass": "^1.101.0",
    "storybook": "^8.6.14",
    "tsx": "^4.23.1",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
